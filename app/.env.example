# Helius RPC (free devnet tier: https://helius.dev)
VITE_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Privy (https://dashboard.privy.io)
VITE_PRIVY_APP_ID=

# World ID (https://developer.worldcoin.org)
VITE_WORLD_ID_APP_ID=

# MoonPay (https://dashboard.moonpay.com)
VITE_MOONPAY_API_KEY=
VITE_MOONPAY_ENV=sandbox

# Covalent / GoldRush (https://goldrush.dev) — used by Insights tab and Income
# History page on mainnet. Optional: app falls back to direct Solana RPC if
# unset, on devnet, or if the user toggles "Direct RPC" in the analytics banner.
VITE_COVALENT_API_KEY=
