# Helius RPC (free devnet tier: https://helius.dev)
VITE_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Privy (https://dashboard.privy.io)
VITE_PRIVY_APP_ID=

# World ID (https://developer.worldcoin.org)
VITE_WORLD_ID_APP_ID=

# MoonPay (https://dashboard.moonpay.com)
VITE_MOONPAY_API_KEY=
VITE_MOONPAY_ENV=sandbox

# Demo / tour mode. When set to a Solana pubkey, the landing page surfaces
# "View employer/employee demo" links that route to ?demo=1 — read-only views
# of the seeded showcase org owned by this authority. Set this AFTER running
# scripts/seed-devnet.ts to the pubkey of the keypair you used as authority.
VITE_DEMO_ORG_AUTHORITY=

# Demo authority secret key (64-byte JSON array). Used by scripts/seed-devnet.ts
# to sign on-chain transactions when populating the showcase org.
# CRITICAL: never prefix with VITE_ — Vite would bundle it into the browser.
# Keep this in .env.local (gitignored) and out of any deploy environment.
DEMO_AUTHORITY_KEYPAIR=

